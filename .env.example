# More Munch 환경 변수
# 이 파일을 .env로 복사한 후 값을 채워주세요: cp .env.example .env

# 카카오 REST API 키 (https://developers.kakao.com 에서 발급)
KAKAO_REST_API_KEY=your-kakao-rest-api-key

# 네이버 검색 API (https://developers.naver.com 에서 발급)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# 사용자 인증용 API 키 (seed 시 생성되는 키, 아무 문자열 가능)
SEED_API_KEY=change-me-to-random-string

# 세션 시크릿 (관리자 대시보드용, 아무 문자열 가능)
SESSION_SECRET=change-me-to-random-string
