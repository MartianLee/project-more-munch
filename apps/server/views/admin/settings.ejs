<%- include('../partials/header') %>

<h1 class="text-2xl font-bold mb-4">설정 & 수집</h1>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

  <!-- Settings Form -->
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-lg">검색 설정</h2>
      <form
        hx-post="/admin/settings"
        hx-target="#settings-message"
        hx-swap="innerHTML"
      >
        <div class="space-y-3">
          <div class="form-control">
            <label class="label label-text text-sm">위도</label>
            <input type="number" step="any" name="latitude" value="<%= settings ? settings.latitude : '' %>" class="input input-bordered input-sm" required />
          </div>
          <div class="form-control">
            <label class="label label-text text-sm">경도</label>
            <input type="number" step="any" name="longitude" value="<%= settings ? settings.longitude : '' %>" class="input input-bordered input-sm" required />
          </div>
          <div class="form-control">
            <label class="label label-text text-sm">도보 시간 (분)</label>
            <input type="number" name="walkMinutes" value="<%= settings ? settings.walkMinutes : 10 %>" class="input input-bordered input-sm" required />
          </div>
          <div class="form-control">
            <label class="label label-text text-sm">최소 평점</label>
            <input type="number" step="0.1" name="minRating" value="<%= settings ? settings.minRating : 3.5 %>" class="input input-bordered input-sm" required />
          </div>
          <div class="form-control">
            <label class="label label-text text-sm">제외 일수</label>
            <input type="number" name="excludeDays" value="<%= settings ? settings.excludeDays : 5 %>" class="input input-bordered input-sm" required />
            <label class="label">
              <span class="label-text-alt text-base-content/50">최근 N일 내 방문한 식당 제외</span>
            </label>
          </div>
        </div>

        <div id="settings-message" class="mt-3"></div>

        <div class="mt-3">
          <button type="submit" class="btn btn-primary btn-sm">
            저장
            <span class="htmx-indicator loading loading-spinner loading-xs"></span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Collection Status -->
  <div class="space-y-6">
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title text-lg">수집 현황</h2>
        <div class="stats stats-vertical shadow">
          <div class="stat">
            <div class="stat-title">마지막 수집</div>
            <div class="stat-value text-sm"><%= lastSyncTime || '-' %></div>
          </div>
          <div class="stat">
            <div class="stat-title">활성 식당</div>
            <div class="stat-value text-primary"><%= activeCount %></div>
          </div>
          <div class="stat">
            <div class="stat-title">비활성 식당</div>
            <div class="stat-value text-base-content/50"><%= inactiveCount %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h2 class="card-title text-lg">수동 수집</h2>
        <p class="text-sm text-base-content/60">수집 버튼을 누르면 식당 데이터를 다시 수집합니다.</p>
        <div class="mt-3">
          <button
            class="btn btn-secondary btn-sm"
            hx-post="/collector/run"
            hx-swap="none"
            hx-indicator="#collect-indicator"
            hx-on::after-request="if(event.detail.successful) { document.getElementById('collect-result').innerHTML = '<div class=\'alert alert-success py-2 mt-2\'><span class=\'text-sm\'>수집이 완료되었습니다. 페이지를 새로고침하세요.</span></div>'; } else { document.getElementById('collect-result').innerHTML = '<div class=\'alert alert-error py-2 mt-2\'><span class=\'text-sm\'>수집 중 오류가 발생했습니다.</span></div>'; }"
          >
            수집 시작
            <span id="collect-indicator" class="htmx-indicator loading loading-spinner loading-xs"></span>
          </button>
          <div id="collect-result"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>
