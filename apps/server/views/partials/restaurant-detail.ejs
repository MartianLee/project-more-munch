<div class="modal modal-open" id="restaurant-modal">
  <div class="modal-box max-w-2xl">
    <h3 class="font-bold text-lg mb-4"><%= restaurant.name %></h3>

    <!-- Restaurant Edit Form -->
    <form
      hx-post="/admin/restaurants/<%= restaurant.id %>"
      hx-target="#modal-container"
      hx-swap="innerHTML"
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="form-control">
          <label class="label label-text text-xs">식당명</label>
          <input type="text" name="name" value="<%= restaurant.name %>" class="input input-bordered input-sm" required />
        </div>
        <div class="form-control">
          <label class="label label-text text-xs">카테고리</label>
          <input type="text" name="category" value="<%= restaurant.category || '' %>" class="input input-bordered input-sm" />
        </div>
        <div class="form-control sm:col-span-2">
          <label class="label label-text text-xs">주소</label>
          <input type="text" name="address" value="<%= restaurant.address %>" class="input input-bordered input-sm" required />
        </div>
        <div class="form-control">
          <label class="label label-text text-xs">가격대</label>
          <input type="text" name="priceRange" value="<%= restaurant.priceRange || '' %>" class="input input-bordered input-sm" />
        </div>
        <div class="form-control">
          <label class="label label-text text-xs">상태</label>
          <select name="isActive" class="select select-bordered select-sm">
            <option value="true" <%= restaurant.isActive ? 'selected' : '' %>>활성</option>
            <option value="false" <%= !restaurant.isActive ? 'selected' : '' %>>비활성</option>
          </select>
        </div>
      </div>

      <% if (message) { %>
        <div class="alert alert-success mt-3 py-2">
          <span class="text-sm"><%= message %></span>
        </div>
      <% } %>

      <div class="mt-3">
        <button type="submit" class="btn btn-primary btn-sm">
          저장
          <span class="htmx-indicator loading loading-spinner loading-xs"></span>
        </button>
      </div>
    </form>

    <div class="divider"></div>

    <!-- Menu List -->
    <h4 class="font-semibold mb-2">메뉴 (<%= restaurant.menus.length %>)</h4>

    <div id="menu-list">
      <% if (restaurant.menus.length === 0) { %>
        <p class="text-sm text-base-content/50">등록된 메뉴가 없습니다</p>
      <% } else { %>
        <div class="space-y-1">
          <% restaurant.menus.forEach(m => { %>
            <div class="flex items-center justify-between bg-base-200 rounded px-3 py-1.5">
              <span class="text-sm">
                <%= m.name %>
                <% if (m.price) { %>
                  <span class="text-base-content/50 ml-1"><%= m.price.toLocaleString() %>원</span>
                <% } %>
              </span>
              <button
                class="btn btn-ghost btn-xs text-error"
                hx-post="/admin/restaurants/<%= restaurant.id %>/menus/<%= m.id %>/delete"
                hx-target="#modal-container"
                hx-swap="innerHTML"
                hx-confirm="메뉴를 삭제하시겠습니까?"
              >삭제</button>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Add Menu Form -->
    <form
      hx-post="/admin/restaurants/<%= restaurant.id %>/menus"
      hx-target="#modal-container"
      hx-swap="innerHTML"
      class="flex gap-2 mt-3"
    >
      <input type="text" name="name" placeholder="메뉴명" class="input input-bordered input-sm flex-1" required />
      <input type="number" name="price" placeholder="가격" class="input input-bordered input-sm w-28" />
      <button type="submit" class="btn btn-secondary btn-sm">추가</button>
    </form>

    <div class="modal-action">
      <button class="btn btn-sm" onclick="document.getElementById('modal-container').innerHTML=''">닫기</button>
    </div>
  </div>
  <div class="modal-backdrop" onclick="document.getElementById('modal-container').innerHTML=''"></div>
</div>
